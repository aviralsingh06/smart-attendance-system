# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret — change this to a random string in production
JWT_SECRET=your_super_secret_jwt_key_change_me

# OpenAI API Key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_key_here

# Database path (optional — defaults to database.json in backend folder)
# On Vercel serverless, data is stored in /tmp (ephemeral)
DATABASE_PATH=./database.json

# Faculty phone for WhatsApp alerts (country code + number, no + sign)
FACULTY_PHONE=919876543210
